{
  "outputStyle": "Limpid",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|mcp__patches__apply_patches|mcp__patches__retry_patches",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/precedent-gate.sh\"",
            "statusMessage": "Checking precedent citation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r filepath; if [[ \"$filepath\" == *.lua ]]; then project_root=\"$CLAUDE_PROJECT_DIR\"; [[ \"$filepath\" == \"$project_root\"/* ]] && relpath=\"${filepath#$project_root/}\" && [[ \"$relpath\" != */* ]] && cd \"$project_root\" && python3 tools/map_extract.py \"$relpath\" map/ 2>/dev/null || true; fi; }",
            "statusMessage": "Regenerating .map file..."
          }
        ]
      },
      {
        "matcher": "mcp__patches__apply_patches|mcp__patches__retry_patches",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/patches-map-regen.sh\"",
            "statusMessage": "Regenerating stale .map files..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|mcp__patches__apply_patches|mcp__patches__retry_patches",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/precedent-consume.sh\"",
            "statusMessage": "Consuming precedent citation..."
          }
        ]
      }
    ]
  }
}
